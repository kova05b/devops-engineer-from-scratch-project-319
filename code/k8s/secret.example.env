# Скопируй в .env.local-k8s и подставь значения.
# Для продакшена предпочтительно Yandex Lockbox + External Secrets (см. README).
SPRING_DATASOURCE_URL=jdbc:postgresql://<postgres-fqdn>:5432/bulletins
SPRING_DATASOURCE_USERNAME=bulletins
SPRING_DATASOURCE_PASSWORD=CHANGE_ME
STORAGE_S3_ACCESSKEY=CHANGE_ME
STORAGE_S3_SECRETKEY=CHANGE_ME
